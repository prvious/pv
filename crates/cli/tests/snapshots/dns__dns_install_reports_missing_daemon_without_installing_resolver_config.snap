---
source: crates/cli/tests/dns.rs
expression: "(output, prepared_path, prepared_config, system_resolver_config,\nenvironment.operations.borrow().clone(),)"
---
(
    RunOutput {
        exit_code: ExitCode(
            unix_exit_status(
                1,
            ),
        ),
        stdout: "Prepared PV DNS resolver config\n  path: <tempdir>/home/.pv/config/resolver/test\n  DNS resolver port: <dns-port>\nPV daemon is not running; .test lookups will not resolve yet.\nRun `pv setup` or `pv daemon:enable`, then retry `pv dns:install`.\n  socket: <tempdir>/home/.pv/run/pv.sock\n",
        stderr: "",
    },
    "<tempdir>/home/.pv/config/resolver/test",
    "# Managed by PV\n# Source: PV prepared resolver config for /etc/resolver/test\nnameserver 127.0.0.1\nport <dns-port>\n",
    None,
    [],
)
