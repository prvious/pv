---
source: crates/cli/tests/daemon.rs
expression: "(output, environment.operations(), plist)"
---
(
    RunOutput {
        exit_code: ExitCode(
            unix_exit_status(
                0,
            ),
        ),
        stdout: "LaunchAgent installed: <tempdir>/Library/LaunchAgents/com.prvious.pv.daemon.plist\nDaemon started\nDaemon healthy\nSystem reconciliation requested: job_enable_1\n",
        stderr: "",
    },
    [
        "bootstrap <tempdir>/Library/LaunchAgents/com.prvious.pv.daemon.plist",
        "kickstart com.prvious.pv.daemon",
    ],
    "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<!-- Managed by PV -->\n<!DOCTYPE plist PUBLIC \"-//Apple//DTD PLIST 1.0//EN\" \"https://www.apple.com/DTDs/PropertyList-1.0.dtd\">\n<plist version=\"1.0\">\n<dict>\n  <key>Label</key>\n  <string>com.prvious.pv.daemon</string>\n  <key>ProgramArguments</key>\n  <array>\n    <string><tempdir>/pv</string>\n    <string>daemon:run</string>\n  </array>\n  <key>KeepAlive</key>\n  <true/>\n  <key>RunAtLoad</key>\n  <true/>\n  <key>StandardOutPath</key>\n  <string><tempdir>/home/.pv/logs/launchd.out.log</string>\n  <key>StandardErrorPath</key>\n  <string><tempdir>/home/.pv/logs/launchd.err.log</string>\n</dict>\n</plist>\n",
)
