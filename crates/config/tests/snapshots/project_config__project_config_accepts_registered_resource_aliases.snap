---
source: crates/config/tests/project_config.rs
expression: config.resources
---
{
    "mailpit": ResourceConfig {
        track: None,
        env: {
            "MAIL_HOST": "${smtp_host}",
        },
        allocations: {},
    },
    "postgres": ResourceConfig {
        track: Some(
            "latest",
        ),
        env: {},
        allocations: {},
    },
    "rustfs": ResourceConfig {
        track: None,
        env: {},
        allocations: {
            "app": AllocationConfig {
                env: {
                    "S3_BUCKET": "${bucket}",
                },
            },
        },
    },
}
