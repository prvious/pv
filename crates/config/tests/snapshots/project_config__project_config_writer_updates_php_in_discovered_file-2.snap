---
source: crates/config/tests/project_config.rs
expression: "read_file(&project.join(\"pv.yml\"))?"
---
php: '8.4'
document_root: public
hostnames:
- admin.acme.test
env:
  APP_URL: ${project_url}
mysql:
  version: '8.0'
  env:
    DB_HOST: ${host}
  allocations:
    app-db:
      env:
        DB_DATABASE: ${database}
postgres:
  version: latest
