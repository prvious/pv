---
source: crates/daemon/tests/gateway_reconciliation.rs
expression: plan
---
RuntimePlan {
    gateway: GatewayRuntimePlan {
        http_port: 48080,
        https_port: 48443,
        ca_certificate_path: "<tempdir>/home/.pv/certificates/ca.pem",
        ca_private_key_path: "<tempdir>/home/.pv/certificates/ca-key.pem",
    },
    workers: [
        PhpWorkerRuntimePlan {
            php_track: "8.4",
            port: 45000,
            projects: [
                RuntimeProject {
                    id: "<project_id>",
                    primary_hostname: "latest.test",
                    hostnames: [],
                    project_root: "<tempdir>/latest-project",
                    document_root: "<tempdir>/latest-project/public",
                },
            ],
        },
    ],
}
