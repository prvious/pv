---
source: crates/daemon/tests/gateway_config.rs
expression: render_gateway_config(&input)?
---
{
    admin off
    http_port 48080
    https_port 48443
    pki {
        ca local {
            root {
                format pem_file
                cert "/Users/alice/.pv/certificates/ca.pem"
                key "/Users/alice/.pv/certificates/ca-key.pem"
            }
        }
    }
}

acme.test, api.acme.test {
    bind 127.0.0.1 ::1
    tls {
        issuer internal {
            ca local
        }
    }
    reverse_proxy 127.0.0.1:45001 {
        header_up Host {host}
        header_up X-Forwarded-Host {host}
        header_up X-Forwarded-Proto {scheme}
        header_up X-Forwarded-For {remote_host}
    }
}
