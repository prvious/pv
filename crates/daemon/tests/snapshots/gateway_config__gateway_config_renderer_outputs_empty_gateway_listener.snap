---
source: crates/daemon/tests/gateway_config.rs
expression: render_gateway_config(&input)?
---
# PV_FAKE_PORT 48080
{
    admin off
    storage file_system {
        root "/Users/alice/.pv/certificates/caddy"
    }
    http_port 48080
    https_port 48443
    pki {
        ca local {
            root {
                format pem_file
                cert "/Users/alice/.pv/certificates/ca.pem"
                key "/Users/alice/.pv/certificates/ca-key.pem"
            }
        }
    }
}

:48080 {
    bind 127.0.0.1 ::1
    respond "PV Gateway is running" 404
}
