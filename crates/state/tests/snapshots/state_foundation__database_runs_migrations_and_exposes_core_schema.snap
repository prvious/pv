---
source: crates/state/tests/state_foundation.rs
expression: database.inspect()?
---
DatabaseInspection {
    busy_timeout_ms: 250,
    foreign_keys_enabled: true,
    journal_mode: "wal",
    migrations: [
        "001:core_state_schema",
        "002:managed_resource_removal_intent",
        "003:project_primary_hostname_updates",
        "004:project_original_path",
        "005:project_resource_requirements",
        "006:global_php_default",
        "007:resource_port_roles",
        "008:project_php_runtime_extensions",
    ],
    tables: [
        "global_php_default_track",
        "jobs",
        "managed_resource_tracks",
        "observed_states",
        "ports",
        "project_env_observed_warnings",
        "project_hostnames",
        "project_managed_resources",
        "projects",
        "pv_migrations",
        "resource_allocations",
        "resource_ports",
    ],
}
