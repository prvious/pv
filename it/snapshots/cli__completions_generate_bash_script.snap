                ;;
            pv,mail:install)
                cmd="pv__subcmd__mail:install"
                ;;
            pv,mail:list)
                cmd="pv__subcmd__mail:list"
                ;;
            pv,mail:open)
                cmd="pv__subcmd__mail:open"
                ;;
            pv,mail:uninstall)
                cmd="pv__subcmd__mail:uninstall"
                ;;
            pv,mail:update)
