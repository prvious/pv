---
source: it/cli.rs
expression: output.stdout
---
#compdef pv

autoload -U is-at-least

_pv() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_pv_commands" \
"*::: :->pv" \
&& ret=0
    case $state in
    (pv)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:pv-command-$line[1]:"
        case $line[1] in
            (env)
_arguments "${_arguments_options[@]}" : \
'--shell=[Shell syntax to generate]:SHELL:(bash fish zsh)' \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Shell to generate completions for:(bash fish zsh)' \
&& ret=0
;;
(daemon:enable)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(daemon:disable)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(daemon:restart)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(daemon:run)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(dns:status)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(dns:install)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(dns:uninstall)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(link)
_arguments "${_arguments_options[@]}" : \
'--hostname=[Primary .test hostname]:hostname:_default' \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
'::path -- Project path to link:_default' \
&& ret=0
;;
(unlink)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
'::hostname -- Project hostname to unlink:_default' \
&& ret=0
;;
(open)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
'::hostname -- Project hostname to open:_default' \
&& ret=0
;;
(project:env)
_arguments "${_arguments_options[@]}" : \
'--json[Print generated Project environment values as JSON]' \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
'::hostname -- Project hostname to render env for:_default' \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(php:install)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
'::track -- PHP track to install:_default' \
&& ret=0
;;
        esac
    ;;
esac
}

(( $+functions[_pv_commands] )) ||
_pv_commands() {
    local commands; commands=(
'env:Print shell integration code' \
'completions:Generate shell completions' \
'daemon:enable:Enable the PV login daemon' \
'daemon:disable:Disable the PV login daemon' \
'daemon:restart:Restart the PV login daemon' \
'daemon:run:Run the internal PV daemon' \
'dns:status:Show PV .test resolver status' \
'dns:install:Prepare PV .test resolver config' \
'dns:uninstall:Remove prepared PV .test resolver config' \
'link:Link a Project' \
'unlink:Unlink a Project' \
'open:Open a linked Project' \
'project:env:Print generated Project environment values' \
'list:List linked Projects' \
'php:install:Install a PHP track' \
    )
    _describe -t commands 'pv commands' commands "$@"
}
(( $+functions[_pv__subcmd__completions_commands] )) ||
_pv__subcmd__completions_commands() {
    local commands; commands=()
    _describe -t commands 'pv completions commands' commands "$@"
}
(( $+functions[_pv__subcmd__daemon:disable_commands] )) ||
_pv__subcmd__daemon:disable_commands() {
    local commands; commands=()
    _describe -t commands 'pv daemon:disable commands' commands "$@"
}
(( $+functions[_pv__subcmd__daemon:enable_commands] )) ||
_pv__subcmd__daemon:enable_commands() {
    local commands; commands=()
    _describe -t commands 'pv daemon:enable commands' commands "$@"
}
(( $+functions[_pv__subcmd__daemon:restart_commands] )) ||
_pv__subcmd__daemon:restart_commands() {
    local commands; commands=()
    _describe -t commands 'pv daemon:restart commands' commands "$@"
}
(( $+functions[_pv__subcmd__daemon:run_commands] )) ||
_pv__subcmd__daemon:run_commands() {
    local commands; commands=()
    _describe -t commands 'pv daemon:run commands' commands "$@"
}
(( $+functions[_pv__subcmd__dns:install_commands] )) ||
_pv__subcmd__dns:install_commands() {
    local commands; commands=()
    _describe -t commands 'pv dns:install commands' commands "$@"
}
(( $+functions[_pv__subcmd__dns:status_commands] )) ||
_pv__subcmd__dns:status_commands() {
    local commands; commands=()
    _describe -t commands 'pv dns:status commands' commands "$@"
}
(( $+functions[_pv__subcmd__dns:uninstall_commands] )) ||
_pv__subcmd__dns:uninstall_commands() {
    local commands; commands=()
    _describe -t commands 'pv dns:uninstall commands' commands "$@"
}
(( $+functions[_pv__subcmd__env_commands] )) ||
_pv__subcmd__env_commands() {
    local commands; commands=()
    _describe -t commands 'pv env commands' commands "$@"
}
(( $+functions[_pv__subcmd__link_commands] )) ||
_pv__subcmd__link_commands() {
    local commands; commands=()
    _describe -t commands 'pv link commands' commands "$@"
}
(( $+functions[_pv__subcmd__list_commands] )) ||
_pv__subcmd__list_commands() {
    local commands; commands=()
    _describe -t commands 'pv list commands' commands "$@"
}
(( $+functions[_pv__subcmd__open_commands] )) ||
_pv__subcmd__open_commands() {
    local commands; commands=()
    _describe -t commands 'pv open commands' commands "$@"
}
(( $+functions[_pv__subcmd__php:install_commands] )) ||
_pv__subcmd__php:install_commands() {
    local commands; commands=()
    _describe -t commands 'pv php:install commands' commands "$@"
}
(( $+functions[_pv__subcmd__project:env_commands] )) ||
_pv__subcmd__project:env_commands() {
    local commands; commands=()
    _describe -t commands 'pv project:env commands' commands "$@"
}
(( $+functions[_pv__subcmd__unlink_commands] )) ||
_pv__subcmd__unlink_commands() {
    local commands; commands=()
    _describe -t commands 'pv unlink commands' commands "$@"
}

if [ "$funcstack[1]" = "_pv" ]; then
    _pv "$@"
else
    compdef _pv pv
fi
