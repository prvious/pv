    _describe -t commands 'pv project:env commands' commands "$@"
}
(( $+functions[_pv__subcmd__setup_commands] )) ||
_pv__subcmd__setup_commands() {
    local commands; commands=()
    _describe -t commands 'pv setup commands' commands "$@"
}
(( $+functions[_pv__subcmd__uninstall_commands] )) ||
_pv__subcmd__uninstall_commands() {
