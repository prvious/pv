---
source: it/cli.rs
expression: output.stdout
---
#compdef pv

autoload -U is-at-least

_pv() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_pv_commands" \
"*::: :->pv" \
&& ret=0
    case $state in
    (pv)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:pv-command-$line[1]:"
        case $line[1] in
            (env)
_arguments "${_arguments_options[@]}" : \
'--shell=[Shell syntax to generate]:SHELL:(bash fish zsh)' \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Shell to generate completions for:(bash fish zsh)' \
&& ret=0
;;
(setup)
_arguments "${_arguments_options[@]}" : \
'--yes[Accept PV-owned setup confirmations]' \
'--non-interactive[Disable interactive prompts]' \
'--no-path[Skip shell profile integration]' \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(uninstall)
_arguments "${_arguments_options[@]}" : \
'--prune[Remove PV-owned state under ~/.pv]' \
'--force[Skip prune confirmation]' \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(daemon:enable)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(daemon:disable)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(daemon:restart)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(daemon:run)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(dns:status)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(dns:install)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(dns:uninstall)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(ports:status)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(ports:install)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(ports:uninstall)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(ca:status)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(ca:trust)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(ca:untrust)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(link)
_arguments "${_arguments_options[@]}" : \
'--hostname=[Primary .test hostname]:hostname:_default' \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
'::path -- Project path to link:_default' \
&& ret=0
;;
(unlink)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
'::hostname -- Project hostname to unlink:_default' \
&& ret=0
;;
(open)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
'::hostname -- Project hostname to open:_default' \
&& ret=0
;;
(project:env)
_arguments "${_arguments_options[@]}" : \
'--json[Print generated Project environment values as JSON]' \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
'::hostname -- Project hostname to render env for:_default' \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(php:use)
_arguments "${_arguments_options[@]}" : \
'-g[Set the global PHP default]' \
'--global[Set the global PHP default]' \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
':track -- PHP track to use:_default' \
&& ret=0
;;
(php:install)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
'::track -- PHP track to install:_default' \
&& ret=0
;;
(php:update)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(php:uninstall)
_arguments "${_arguments_options[@]}" : \
'--prune[Remove PV-owned runtime data for the track]' \
'--force[Remove the track even if Projects use it]' \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
':track -- PHP track to uninstall:_default' \
&& ret=0
;;
(php:list)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
        esac
    ;;
esac
}

(( $+functions[_pv_commands] )) ||
_pv_commands() {
    local commands; commands=(
'env:Print shell integration code' \
'completions:Generate shell completions' \
'setup:Configure PV system integrations' \
'uninstall:Uninstall PV safely' \
'daemon:enable:Enable the PV login daemon' \
'daemon:disable:Disable the PV login daemon' \
'daemon:restart:Restart the PV login daemon' \
'daemon:run:Run the internal PV daemon' \
'dns:status:Show PV .test resolver status' \
'dns:install:Install or repair PV .test resolver config' \
'dns:uninstall:Remove PV .test resolver config' \
'ports:status:Show PV pf redirect status' \
'ports:install:Install or repair PV pf redirects' \
'ports:uninstall:Remove PV pf redirects' \
'ca:status:Show PV local CA trust status' \
'ca:trust:Trust PV local CA in the System keychain' \
'ca:untrust:Remove PV local CA trust' \
'link:Link a Project' \
'unlink:Unlink a Project' \
'open:Open a linked Project' \
'project:env:Print generated Project environment values' \
'list:List linked Projects' \
'php:use:Set the PHP track' \
'php:install:Install a PHP track' \
'php:update:Update installed PHP tracks' \
'php:uninstall:Uninstall a PHP track' \
'php:list:List installed PHP tracks' \
    )
    _describe -t commands 'pv commands' commands "$@"
}
(( $+functions[_pv__subcmd__ca:status_commands] )) ||
_pv__subcmd__ca:status_commands() {
    local commands; commands=()
    _describe -t commands 'pv ca:status commands' commands "$@"
}
(( $+functions[_pv__subcmd__ca:trust_commands] )) ||
_pv__subcmd__ca:trust_commands() {
