;;
(composer:uninstall)
_arguments "${_arguments_options[@]}" : \
'--prune[Remove PV-owned Composer home/cache]' \
'--force[Remove Composer even if in use]' \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(mailpit:install)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
