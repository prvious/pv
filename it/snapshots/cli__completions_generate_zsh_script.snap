(( $+functions[_pv_commands] )) ||
_pv_commands() {
    local commands; commands=(
'env:Print shell integration code' \
'completions:Generate shell completions' \
'setup:Configure PV system integrations' \
'uninstall:Uninstall PV safely' \
'daemon:enable:Enable the PV login daemon' \
'daemon:disable:Disable the PV login daemon' \
'daemon:restart:Restart the PV login daemon' \
'daemon:run:Run the internal PV daemon' \
'shim:php:Run the internal PV PHP shim' \
'shim:composer:Run the internal PV Composer shim' \
'dns:status:Show PV .test resolver status' \
'dns:install:Install or repair PV .test resolver config' \
'dns:uninstall:Remove PV .test resolver config' \
'ports:status:Show PV pf redirect status' \
'ports:install:Install or repair PV pf redirects' \
'ports:uninstall:Remove PV pf redirects' \
'ca:status:Show PV local CA trust status' \
'ca:trust:Trust PV local CA in the System keychain' \
'ca:untrust:Remove PV local CA trust' \
'link:Link a Project' \
'unlink:Unlink a Project' \
'open:Open a linked Project' \
'project:env:Print generated Project environment values' \
'status:Show whole-system PV status' \
'logs:Show PV logs' \
'doctor:Run read-only PV diagnostics' \
'jobs:List recent daemon jobs' \
'update:Update PV or preview available updates with --check' \
'list:List linked Projects' \
'php:use:Set the PHP track' \
'php:install:Install a PHP track' \
'php:update:Update installed PHP tracks' \
'php:uninstall:Uninstall a PHP track' \
'php:list:List installed PHP tracks' \
'composer:install:Install Composer track 2' \
'composer:update:Update Composer track 2' \
'composer:uninstall:Uninstall Composer' \
'mailpit:install:Install a Mailpit track' \
'mailpit:update:Update installed Mailpit tracks' \
'mailpit:uninstall:Uninstall a Mailpit track' \
'mailpit:list:List installed Mailpit tracks' \
'mailpit:open:Open the running Mailpit dashboard' \
'mail:install:Install a Mailpit track' \
'mail:update:Update installed Mailpit tracks' \
'mail:uninstall:Uninstall a Mailpit track' \
'mail:list:List installed Mailpit tracks' \
'mail:open:Open the running Mailpit dashboard' \
'redis:install:Install a Redis track' \
'redis:update:Update installed Redis tracks' \
'redis:uninstall:Uninstall a Redis track' \
'redis:list:List installed Redis tracks' \
'rustfs:install:Install a RustFS track' \
'rustfs:update:Update installed RustFS tracks' \
'rustfs:uninstall:Uninstall a RustFS track' \
'rustfs:list:List installed RustFS tracks' \
'rustfs:open:Open the running RustFS console' \
's3:install:Install a RustFS track (S3 alias)' \
's3:update:Update installed RustFS tracks (S3 alias)' \
's3:uninstall:Uninstall a RustFS track (S3 alias)' \
's3:list:List installed RustFS tracks (S3 alias)' \
's3:open:Open the running RustFS console (S3 alias)' \
'mysql:install:Install a MySQL track' \
'mysql:update:Update installed MySQL tracks' \
'mysql:uninstall:Uninstall a MySQL track' \
'mysql:list:List installed MySQL tracks' \
'postgres:install:Install a Postgres track' \
'postgres:update:Update installed Postgres tracks' \
'postgres:uninstall:Uninstall a Postgres track' \
'postgres:list:List installed Postgres tracks' \
'pg:install:Install a Postgres track' \
'pg:update:Update installed Postgres tracks' \
'pg:uninstall:Uninstall a Postgres track' \
'pg:list:List installed Postgres tracks' \
    )
    _describe -t commands 'pv commands' commands "$@"
}
(( $+functions[_pv__subcmd__ca:status_commands] )) ||
_pv__subcmd__ca:status_commands() {
    local commands; commands=()
    _describe -t commands 'pv ca:status commands' commands "$@"
}
