---
source: it/cli.rs
expression: output.stdout
---
#compdef pv

autoload -U is-at-least

_pv() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_pv_commands" \
"*::: :->pv" \
&& ret=0
    case $state in
    (pv)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:pv-command-$line[1]:"
        case $line[1] in
            (env)
_arguments "${_arguments_options[@]}" : \
'--shell=[Shell syntax to generate]:SHELL:(bash fish zsh)' \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Shell to generate completions for:(bash fish zsh)' \
&& ret=0
;;
(setup)
_arguments "${_arguments_options[@]}" : \
'--yes[Accept PV-owned setup confirmations]' \
'--non-interactive[Disable interactive prompts]' \
'--no-path[Skip shell profile integration]' \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(uninstall)
_arguments "${_arguments_options[@]}" : \
'--prune[Remove PV-owned state under ~/.pv]' \
'--force[Skip prune confirmation]' \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(daemon:enable)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(daemon:disable)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(daemon:restart)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(daemon:run)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(shim:php)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'*::args:_default' \
&& ret=0
;;
(shim:composer)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'*::args:_default' \
&& ret=0
;;
(dns:status)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(dns:install)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(dns:uninstall)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(ports:status)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(ports:install)
_arguments "${_arguments_options[@]}" : \
