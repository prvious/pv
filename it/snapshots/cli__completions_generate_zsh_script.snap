'--help[Print help]' \
&& ret=0
;;
(ca:untrust)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(link)
_arguments "${_arguments_options[@]}" : \
'--hostname=[Primary .test hostname]:hostname:_default' \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
'::path -- Project path to link:_default' \
&& ret=0
;;
(unlink)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
'::hostname -- Project hostname to unlink:_default' \
&& ret=0
;;
(open)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
'::hostname -- Project hostname to open:_default' \
&& ret=0
;;
(project:env)
_arguments "${_arguments_options[@]}" : \
'--json[Print generated Project environment values as JSON]' \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
'::hostname -- Project hostname to render env for:_default' \
&& ret=0
;;
(status)
_arguments "${_arguments_options[@]}" : \
'--json[Print whole-system status as JSON]' \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(logs)
_arguments "${_arguments_options[@]}" : \
'-n+[Number of recent lines to show]:LINES:_default' \
'--lines=[Number of recent lines to show]:LINES:_default' \
'--worker=[Show logs for a PHP worker track]:php-track:_default' \
'--resource=[Show logs for a Managed Resource]:name:_default' \
'--track=[Managed Resource track for --resource]:track:_default' \
'-f[Stream new log lines after the initial tail]' \
'--follow[Stream new log lines after the initial tail]' \
'--all[Include every PV-owned log stream]' \
'--gateway[Show Gateway logs]' \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(doctor)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(jobs)
_arguments "${_arguments_options[@]}" : \
'--json[Print recent daemon jobs as JSON]' \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(update)
_arguments "${_arguments_options[@]}" : \
'--check[Check for updates without applying them]' \
'--json[Print update check output as JSON]' \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
'--json[Print command output as JSON]' \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(php:use)
_arguments "${_arguments_options[@]}" : \
'-g[Set the global PHP default]' \
'--global[Set the global PHP default]' \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
':track -- PHP track to use:_default' \
&& ret=0
;;
(php:install)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
'::track -- PHP track to install:_default' \
&& ret=0
;;
(php:update)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(php:uninstall)
_arguments "${_arguments_options[@]}" : \
'--prune[Remove PV-owned runtime data for the track]' \
'--force[Remove the track even if Projects use it]' \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
':track -- PHP track to uninstall:_default' \
&& ret=0
;;
(php:list)
_arguments "${_arguments_options[@]}" : \
'--json[Print command output as JSON]' \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(composer:install)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(composer:update)
_arguments "${_arguments_options[@]}" : \
'--no-color[Disable colored output]' \
